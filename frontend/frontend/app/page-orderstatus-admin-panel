            <div className="grid grid-cols-2 gap-3">
              <input type="date" value={selectedDate} onChange={(e) => setSelectedDate(e.target.value)} className="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-4 px-4 text-sm font-bold focus:ring-2 ring-rose-500 outline-none" />
              <input type="time" value={selectedTime} onChange={(e) => setSelectedTime(e.target.value)} className="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-4 px-4 text-sm font-bold focus:ring-2 ring-rose-500 outline-none" />
            </div>
          </div>

          <div className="space-y-4">
            <h4 className="text-[10px] font-black uppercase text-slate-400 tracking-[0.2em] ml-1 flex items-center gap-2">
              <Timer size={12} /> Длительность аренды
            </h4>
            <div className="grid grid-cols-3 gap-3">
              {[
                { id: '3h', label: '3 часа', price: selectedItem?.price3h },
                { id: '6h', label: '6 часов', price: selectedItem?.price6h },
                { id: '24h', label: 'Сутки', price: selectedItem?.price24h }
              ].map((t) => (
                <div key={t.id} onClick={() => setSelectedTariff(t.id)} className={`p-4 rounded-[1.5rem] border-2 text-center transition-all cursor-pointer ${selectedTariff === t.id ? 'border-rose-500 bg-rose-50 text-rose-600 shadow-md scale-105 font-bold' : 'border-slate-50 bg-slate-50 opacity-60'}`}>
                  <p className={`text-[9px] font-black uppercase tracking-tighter mb-1 ${selectedTariff === t.id ? 'text-rose-400' : 'text-slate-400'}`}>{t.label}</p>
                  <p className="text-lg font-black leading-none">{t.price}₽</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <button onClick={() => setView('checkout')} className="w-full bg-slate-900 text-white py-6 rounded-[2rem] font-black text-lg shadow-2xl shadow-slate-300 active:scale-95 transition-transform">
          Далее к оплате
        </button>
      </div>
    </div>
  );

  const CheckoutView = () => (
    <div className="animate-in slide-in-from-right duration-300 flex flex-col min-h-screen bg-slate-50">
      <div className="pt-16 pb-8 px-8">
        <button onClick={() => setView('details')} className="bg-white p-3 rounded-2xl shadow-sm mb-8"><ArrowLeft size={20} /></button>
        <h2 className="text-3xl font-black tracking-tighter text-slate-900">Оформление</h2>
      </div>
      <div className="flex-1 bg-white rounded-t-[3.5rem] px-8 pt-10 pb-32 shadow-xl">
        <div className="bg-slate-50 p-6 rounded-[2.5rem] flex items-center gap-4 mb-8">
          <div className={`w-14 h-14 rounded-2xl ${selectedItem?.bg} flex items-center justify-center ${selectedItem?.color}`}><selectedItem.icon size={28} /></div>
          <div>
            <p className="font-black text-slate-800">{selectedItem?.title}</p>
            <p className="text-[10px] font-black text-slate-400 uppercase">{selectedDate} в {selectedTime}</p>
          </div>
        </div>
        <div className="space-y-6 mb-10">
          <h4 className="text-[10px] font-black uppercase text-slate-400 tracking-[0.2em] ml-1">Способ оплаты</h4>
          {['sbp', 'card', 'cash'].map(m => (
            <div key={m} onClick={() => setPaymentMethod(m)} className={`flex items-center gap-4 p-5 rounded-3xl border-2 transition-all cursor-pointer ${paymentMethod === m ? 'border-slate-900 bg-slate-900 text-white shadow-xl' : 'border-slate-100 bg-white'}`}>
              <span className="text-sm font-bold uppercase tracking-tight">{m === 'sbp' ? 'СБП / Т-Банк' : m === 'card' ? 'Картой' : 'Наличными'}</span>
              {paymentMethod === m && <CheckCircle2 size={16} className="ml-auto text-emerald-400" />}
            </div>
          ))}
        </div>
        <button onClick={handleBook} className="w-full bg-rose-500 text-white py-6 rounded-[2rem] font-black text-lg shadow-xl shadow-rose-200">
          Подтвердить
        </button>
      </div>
    </div>
  );

  const MyOrdersView = () => (
    <div className="px-7 pt-16 pb-32 animate-in fade-in flex flex-col flex-1 overflow-y-auto scrollbar-hide">
      <h2 className="text-4xl font-black tracking-tighter italic text-rose-500">Мои брони</h2>
      <div className="mt-8 space-y-4 flex-1">
        {myOrders.map((order) => (
          <div key={order.id} className="bg-white p-6 rounded-[2.5rem] border-2 border-slate-100 relative overflow-hidden">
            <div className={`absolute top-0 right-0 px-4 py-1 rounded-bl-2xl text-[9px] font-black uppercase flex items-center gap-1 ${STATUSES[order.status].color}`}>
              {React.createElement(STATUSES[order.status].icon, { size: 10 })}
              {STATUSES[order.status].label}
            </div>
            <div className="flex gap-4 items-center mb-4">
              <div className={`w-12 h-12 ${order.bg} rounded-2xl flex items-center justify-center ${order.color}`}><order.icon size={24} /></div>
              <div>
                <p className="font-black text-slate-900 text-[15px]">{order.title}</p>
                <p className="text-[10px] font-black text-slate-400 uppercase">{order.date} • {order.time}</p>
              </div>
            </div>
            
            {/* Ревью блок */}
            {order.status === 'returned' && !order.review && (
              <div className="mt-4 p-4 bg-rose-50 rounded-2xl border border-rose-100 animate-pulse">
                <p className="text-[10px] font-black uppercase text-rose-400 mb-2">Вещь возвращена! Оцените прокат:</p>
                <div className="flex gap-2">
                  {[1, 2, 3, 4, 5].map(star => (
                    <button key={star} onClick={() => leaveReview(order.id, star, "")} className="text-amber-400 hover:scale-125 transition-transform"><Star size={20} fill="currentColor" /></button>
                  ))}
                </div>
              </div>
            )}

            {order.review && (
              <div className="mt-4 p-3 bg-slate-50 rounded-2xl flex items-center gap-2">
                <div className="flex"><Star size={10} className="text-amber-400 fill-current" /> <span className="text-xs font-bold ml-1">{order.review.rating}</span></div>
                <span className="text-[10px] font-bold text-slate-400 italic">Ваш отзыв учтен</span>
              </div>
            )}

            <button className="w-full mt-4 bg-slate-50 text-slate-900 py-3 rounded-2xl font-bold text-xs flex items-center justify-center gap-2">
              <MessageCircle size={14} /> Чат с владельцем
            </button>
          </div>
        ))}
        {myOrders.length === 0 && <div className="text-center py-20 text-slate-300 uppercase font-black text-xs tracking-widest">Заказов пока нет</div>}
      </div>
    </div>
  );

  const AdminDashboard = () => (
    <div className="px-7 pt-16 pb-32 animate-in fade-in flex flex-col flex-1 overflow-y-auto scrollbar-hide">
      <div className="flex justify-between items-center mb-8">
        <h2 className="text-3xl font-black tracking-tighter italic text-indigo-600">Админка</h2>
        <div className="bg-indigo-100 text-indigo-600 px-3 py-1 rounded-full text-[10px] font-black">Owner Mode</div>
      </div>

      <div className="space-y-4">
        <h4 className="text-[10px] font-black uppercase text-slate-400 tracking-widest ml-1">Активные запросы</h4>
        {orders.map(order => (
          <div key={order.id} className="bg-white p-5 rounded-[2.5rem] border border-slate-100 shadow-sm relative">
             <div className="flex gap-4 items-center mb-4">
                <div className={`w-12 h-12 ${order.bg} rounded-2xl flex items-center justify-center ${order.color}`}><order.icon size={24} /></div>
                <div className="flex-1">
                  <p className="font-black text-slate-900">{order.title}</p>
                  <p className="text-[9px] font-black text-slate-400 uppercase">Клиент: {order.userId} • {order.price}₽</p>
                </div>
             </div>
             <div className="flex flex-wrap gap-2">
                {Object.entries(STATUSES).map(([key, data]) => (
                  <button 
                    key={key} 
                    onClick={() => updateOrderStatus(order.id, key)}
                    className={`px-3 py-2 rounded-xl text-[9px] font-black uppercase transition-all ${order.status === key ? 'bg-slate-900 text-white shadow-md' : 'bg-slate-100 text-slate-400'}`}
                  >
                    {data.label}
                  </button>
                ))}
             </div>
          </div>
        ))}
        {orders.length === 0 && <div className="text-center py-20 text-slate-300 font-black text-xs uppercase italic tracking-widest">Новых заказов нет</div>}
      </div>
    </div>
  );

  const ProfileView = () => (
    <div className="px-7 pt-16 pb-32 animate-in fade-in overflow-y-auto scrollbar-hide">
      <div className="flex flex-col items-center text-center mb-10">
        <div className="w-24 h-24 rounded-[2.5rem] bg-slate-50 flex items-center justify-center text-slate-200 border-2 border-white shadow-inner">
