# Backend runtime secrets.
# Copy to backend/.env on a server. Do not commit the real backend/.env file.
#
# In Docker Compose production DATABASE_URL is generated in docker-compose.yml
# from POSTGRES_DB, POSTGRES_USER and POSTGRES_PASSWORD in root .env.

ADMIN_EMAILS=admin@prokatilo.com
AUTH_SECRET=change-me-production-auth-secret

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://prokatilo.com

# Generate VAPID keys before enabling production Web Push.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@prokatilo.com

CORS_ORIGINS=https://prokatilo.com,https://www.prokatilo.com,http://prokatilo.com,http://www.prokatilo.com
ENVIRONMENT=production
API_ROOT_PATH=/api
CREATE_TABLES_ON_STARTUP=false

# Local backend-only development can uncomment and adjust this:
# DATABASE_URL=postgresql+asyncpg://prokatilo:change-me-local-postgres-password@localhost:5432/prokatilo
