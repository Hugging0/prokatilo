{
	email {$ACME_EMAIL:admin@myprokatilo.ru}
}

www.{$APP_DOMAIN:myprokatilo.ru} {
	redir https://{$APP_DOMAIN:myprokatilo.ru}{uri} permanent
}

{$APP_DOMAIN:myprokatilo.ru} {
	handle_path /api/* {
		reverse_proxy backend:8000
	}

	handle {
		@private_html path /app /app/* /admin /admin/* /admin-dashboard /admin-dashboard/*
		header @private_html >Cache-Control "no-store, max-age=0, must-revalidate"

		@public_html path / /catalog /catalog/* /rent/* /delivery-area /faq /about /blog /blog/* /privacy /terms /consent /contacts /delivery-payment /llms.txt /llms-full.txt /robots.txt /sitemap.xml
		header @public_html >Cache-Control "public, max-age=300, stale-while-revalidate=3600"
		reverse_proxy frontend:3000
	}
}
