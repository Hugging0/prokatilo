# Docker Compose reads backend secrets from backend/.env.
# Use backend/.env.example and frontend/.env.local.example as templates.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/postgres
ADMIN_API_KEY=change-me
ADMIN_EMAILS=admin@prokatilo.local
AUTH_SECRET=change-me-local-auth-secret
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
ENVIRONMENT=production
CREATE_TABLES_ON_STARTUP=false
